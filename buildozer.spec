[app]

title = Router Killer
package.name = routerkiller
package.domain = org.elcienco

source.dir = .
source.include_exts = py,png,jpg,kv,atlas

version = 1.0.0
requirements = python3,kivy

orientation = portrait
fullscreen = 0

android.permissions = INTERNET, ACCESS_NETWORK_STATE, ACCESS_WIFI_STATE

android.api = 30
android.minapi = 21
android.ndk = 23b

android.sdk = 30
android.ndk_api = 21

log_level = 2
warn_on_root = 0

[buildozer]

log_level = 2
warn_on_root = 1
